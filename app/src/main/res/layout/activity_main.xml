<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/titolo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App Turoldo"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#222222"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/logo"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginTop="24dp"/>

    <ImageView
        android:id="@+id/logo"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/stemma"
        app:layout_constraintTop_toTopOf="@id/titolo"
        app:layout_constraintBottom_toBottomOf="@id/titolo"
        app:layout_constraintStart_toEndOf="@id/titolo"
        android:layout_marginStart="12dp"/>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/orario"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:text="Orario Classi"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        app:backgroundTint="#1565C0"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@id/titolo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ptof"
        android:layout_margin="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ptof"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:text="PTOF"
        android:textSize="16sp"
        android:textColor="@android:color/black"
        app:backgroundTint="#F9A825"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toTopOf="@id/orario"
        app:layout_constraintStart_toEndOf="@id/orario"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/registro"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:text="Registro\nElettronico"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        app:backgroundTint="#C62828"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@id/orario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/libri"
        android:layout_margin="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/libri"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:text="Libri di Testo"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        app:backgroundTint="#00838F"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toTopOf="@id/registro"
        app:layout_constraintStart_toEndOf="@id/registro"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>